# Input for glyw Simulation

1 10          # Line 1: Simulation Mode & Number of Config
              # 1: Annealing; 0: Random configurations
11.0          # Line 2: Simulation Cube Length (Angstroms)

2             # Line 3: Annealing Quenching route
              # (1: Linear, 2: Geometrical).

100.0  10.0  50   # Line 4: Linear Quenching Parameters (Ti, ΔT, steps)

100.0   5.0  20  # Line 5: Geometric Quenching Parameters

3000   50     # Line 6: Maximum Monte Carlo Cycles per T and floor value

1.0  1.0      # Line 7: Maximum Displacement (A) & Rotation (radians)

30  60        # Line 8: Conformational sampling (%)
              # & Maximum dihedral rotation (degrees)

2 orca        # Line 9: QM Program Index & alias
              # (1: Program1, 2: ORCA, 3: Other)

PM3           # Line 10: Hamiltonian & Basis Set
              # (e.g., pm3, hf)(e.g., 6-31G*, STO-3G)

1  4          # Line 11: nprocs (QM calculations and ASCEC evaluation)

0  1          # Line 12: Charge & Spin Multiplicity

2             # Line 13: Number of Molecules (nmo)

# Lines below: Molecule Definition
# (Num Atoms, Label, followed by xyz coordinates, separated by *)

*
8
Glycolaldehyde
O     1.118513    0.971237   -0.102925
O    -1.596188    0.905938   -0.104325
C     0.502113   -0.296863   -0.104725
C    -0.997887   -0.164662   -0.102125
H     0.818213   -0.859962    0.777375
H     0.803512   -0.837263   -1.005825
H    -1.552488   -1.118562   -0.100625
H     0.904212    1.400138    0.743175
*
3
Water
O    -0.294733   -0.218200    0.154167
H    -0.017333    0.674700    0.408567
H     0.312067   -0.456500   -0.562733
*

# Protocol
# (annealing, (pre)optimization, clustering, separated by "," or ".")

.asc,
r2 --box10,
opt input1,
similarity --th=2 -j4,
ref input2,
similarity --th=2 -j4

#orca input1
#name
#rescue(Native-GFN2-xTB/num)
! Native-GFN2-xTB
! Opt NumFreq
%pal
  nprocs 4
end
%geom
  maxiter 50
end
* xyz 0 1
#
*

#orca input2
#name
#rescue(HF-3c/freq)
! BP86 def2-SVP
! Opt Freq
%pal
  nprocs 4
end
%geom
  maxiter 10
end
* xyz 0 1
#
*
